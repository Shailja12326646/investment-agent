PORT=3002

# Required: Google Gemini API key — get free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_YOUR_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash

# Required: Tavily web search — get free at https://app.tavily.com
TAVILY_API_KEY=tvly-YOUR_KEY_HERE

# Optional: For CORS on deployed backend (set to your frontend URL)
ALLOWED_ORIGIN=https://your-frontend.vercel.app

# Optional: Additional financial data sources
FINNHUB_API_KEY=your_finnhub_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
NEWS_API_KEY=your_news_api_key
